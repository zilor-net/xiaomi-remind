<Window x:Class="Xiaomi.Remind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Xiaomi.Remind"
        Title="Xiaomi Remind"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">

    <Window.Resources>
        <FontFamily x:Key="ContentFont">Segoe UI Variable, Microsoft YaHei UI, Segoe UI, 微软雅黑, sans-serif</FontFamily>

        <!-- 导航按钮 -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeNavText}"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource ThemeNavActiveBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeNavActiveFg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 操作按钮 -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLight}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                              TextOptions.TextFormattingMode="Display"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeBtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource ThemeBtnDisabledBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeBtnDisabledFg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBtnDisabledBorder}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                              TextOptions.TextFormattingMode="Display"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1080DD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#006CBE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0A0A0"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#D13438"/>
            <Setter Property="BorderBrush" Value="#D13438"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                              TextOptions.TextFormattingMode="Display"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E04040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B52E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0A0A0"/>
                                <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 列头 -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeDataGridHeaderFg}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeDataGridHeaderBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- DataGrid 单元格 -->
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeDataGridCellFg}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeDataGridSelBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid 行样式 -->
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 设置页卡片 -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SettingTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
        </Style>

        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDesc}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="SettingInput" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeInputFg}"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1080DD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#006CBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 自定义滚动条样式 -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource ThemeTextTertiary}"
                                CornerRadius="4" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarTrackButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="Transparent" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 隐式 ScrollBar 样式，使所有控件（含 ScrollViewer、DataGrid）的内部滚动条也生效 -->
        <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollBar}"/>
    </Window.Resources>

    <Grid Background="{DynamicResource ThemeWindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧导航栏 ===== -->
        <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                BorderBrush="{DynamicResource ThemeBorderLight}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="20,24,20,20"
                        BorderBrush="{DynamicResource ThemeBorderLight}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Xiaomi Remind" FontSize="17" FontWeight="SemiBold"
                               FontFamily="{StaticResource ContentFont}"
                               Foreground="{DynamicResource ThemeTextPrimary}"/>
                </Border>
                <StackPanel Margin="12,12,12,0">
                    <Button x:Name="NavHomeBtn" Margin="0,0,0,4"
                            Command="{Binding NavigateCommand}" CommandParameter="Home"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="主页" FontSize="14" FontFamily="{StaticResource ContentFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettingsBtn" Margin="0,0,0,4"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="设置" FontSize="14" FontFamily="{StaticResource ContentFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 右侧主内容 ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 页面容器（两个面板重叠在同一个 Grid 单元格中） -->
            <Grid x:Name="PageContainer" Grid.Row="0" Margin="20,20,20,12">

                <!-- ===== 主页面板 ===== -->
                <Grid x:Name="HomePagePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 消息卡片 -->
                    <Border Grid.Row="0" Background="{DynamicResource ThemeCardBg}"
                            BorderBrush="{DynamicResource ThemeBorderLight}" BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="20,14,20,12"
                                    BorderBrush="{DynamicResource ThemeBorderLighter}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="消息记录" FontSize="15" FontWeight="SemiBold"
                                               FontFamily="{StaticResource ContentFont}"
                                               Foreground="{DynamicResource ThemeTextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Messages.Count, StringFormat='共 {0} 条'}"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeTextTertiary}"
                                               FontFamily="{StaticResource ContentFont}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding Messages}" Margin="0"
                                      Background="Transparent" BorderThickness="0"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="{DynamicResource ThemeDataGridAltRow}"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      CanUserSortColumns="True" IsReadOnly="True" AutoGenerateColumns="False"
                                      ColumnHeaderHeight="42" RowHeight="48"
                                      FontFamily="{StaticResource ContentFont}" FontSize="13"
                                      UseLayoutRounding="True"
                                      ColumnHeaderStyle="{StaticResource DgHeader}"
                                      CellStyle="{StaticResource DgCell}"
                                      RowStyle="{StaticResource DgRow}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间"
                                                        Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                        Width="180">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="主题" Binding="{Binding Topic}" Width="250">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="内容" Binding="{Binding Payload}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="FontFamily" Value="{StaticResource ContentFont}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- 底部操作按钮 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Content="清空消息" Style="{StaticResource ActionBtn}"
                                Command="{Binding ClearMessagesCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- ===== 设置页面 ===== -->
                <local:SettingsPage x:Name="SettingsPagePanel" Visibility="Collapsed"
                                    DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>

            <!-- ===== 底部状态栏 ===== -->
            <Border Grid.Row="1" Background="{DynamicResource ThemeStatusBarBg}"
                    BorderBrush="{DynamicResource ThemeBorderLight}" BorderThickness="0,1,0,0"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：连接状态 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubscribed}" Value="True">
                                            <Setter Property="Fill" Value="#22c55e"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSubscribed}" Value="False">
                                            <Setter Property="Fill" Value="#ef4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                   FontFamily="{StaticResource ContentFont}"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 中间：MQTT 连接信息（仅已订阅时显示） -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Left" Margin="24,0,0,0"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSubscribed}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Broker 图标 -->
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeTextTertiary}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock FontSize="12"
                                   FontFamily="{StaticResource ContentFont}"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding MqttBroker}"/><Run Text=":"/><Run Text="{Binding MqttPort}"/>
                        </TextBlock>

                        <!-- 分隔符 -->
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{DynamicResource ThemeTextTertiary}"
                                   VerticalAlignment="Center" Margin="16,0,8,0"/>

                        <!-- 订阅主题 图标 -->
                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeTextTertiary}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding MqttTopics}" FontSize="12"
                                   FontFamily="{StaticResource ContentFont}"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 右侧：主题切换 -->
                    <Button Grid.Column="2" Width="36" Height="36" Padding="0"
                            BorderThickness="0" Background="Transparent"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="切换深色/浅色模式" Cursor="Hand">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource ThemeToggleThemeIcon}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE708;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                            <Setter Property="Text" Value="&#xE706;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
